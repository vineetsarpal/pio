# PIO environment configuration.
#
# The Neon Postgres variables (NEON_POSTGRES_*) are provisioned and managed by
# the Stripe Projects CLI in the CLI-managed `.env` — do not hand-edit those.
# The values below are the ones you set yourself (in `.env.local`, gitignored).

# --- Database (Neon Postgres) ---
# Provisioned by Stripe Projects as NEON_POSTGRES_CONNECTION_STRING. The runtime
# policy store and drizzle-kit migrations both read this var. For production
# scale you can point it at the pooled `-pooler` Neon endpoint instead of the
# direct one.
# NEON_POSTGRES_CONNECTION_STRING=postgres://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
