# PIO environment configuration.
#
# Secrets live in two places:
#   - .env        — managed by the Stripe Projects CLI (Neon provisioning). Do
#                   not hand-edit. Provides NEON_POSTGRES_CONNECTION_STRING.
#   - .env.local  — app-managed (gitignored). Put the values below here.

# --- Database (Neon Postgres) ---
# Runtime queries use the POOLED connection string (PgBouncer, the `-pooler`
# host). Copy it from the Neon dashboard into .env.local.
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Migrations (drizzle-kit) use the DIRECT/unpooled string, which Stripe Projects
# provisions as NEON_POSTGRES_CONNECTION_STRING in the CLI-managed .env. DDL
# should not run through PgBouncer transaction-pooling mode.
# NEON_POSTGRES_CONNECTION_STRING=postgres://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
