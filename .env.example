# PIO environment configuration.
#
# The Neon Postgres variables (NEON_POSTGRES_*) are provisioned and managed by
# the Stripe Projects CLI in the CLI-managed `.env` — do not hand-edit those.
# The values below are the ones you set yourself (in `.env.local`, gitignored).

# --- Database (Neon Postgres) ---
# Provisioned by Stripe Projects as NEON_POSTGRES_CONNECTION_STRING. The runtime
# policy store and drizzle-kit migrations both read this var. For production
# scale you can point it at the pooled `-pooler` Neon endpoint instead of the
# direct one.
# NEON_POSTGRES_CONNECTION_STRING=postgres://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DB?sslmode=require

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Headless agent purchase (tracer bullet, issue #6) ---
# One seeded agent key mapped to one seeded Stripe customer with a vaulted test
# card (e.g. pm_card_visa). Deliberately thin; real per-agent identity arrives in
# issue #7. The agent presents PIO_AGENT_SEED_KEY as a Bearer token to
# /api/agent/purchase, which charges PIO_SEED_STRIPE_CUSTOMER off-session.
PIO_AGENT_SEED_KEY=pio_seed_key_...
PIO_AGENT_SEED_ID=agent_seed_demo
PIO_SEED_STRIPE_CUSTOMER=cus_...
PIO_SEED_STRIPE_PAYMENT_METHOD=pm_card_visa
